# ── Shared: Groq API key (both processes read this same variable) ────────────
GROQ_API_KEY="<YOUR_GROQ_API_KEY>"

# ── Cognee memory server (root main.py, port 8010) ────────────────────────────
# litellm-style provider/model string — cognee's config wants this exact format.
LLM_MODEL="groq/llama-3.3-70b-versatile"
LLM_PROVIDER="groq"

# File watcher directory (relative or absolute)
WATCHED_DIR="./watched_runs"

# Auto-improve trigger: call improve_memory() every N remember_run calls
IMPROVE_EVERY_N_RUNS=10

# Ontology grounding (Section 4.4) — set by ontology/ml_ontology.py, override only
# if you move the .owl file elsewhere.
# ONTOLOGY_FILE_PATH="./ontology/ml_ontology.owl"

# Server settings — 8010, NOT 8000: backend/app/main.py (the Postgres app layer)
# also defaults to 8000 and needs to run alongside this server.
HOST="0.0.0.0"
PORT=8010

# ── App backend (backend/app/main.py, port 8000) — Postgres + Groq ───────────
# asyncpg connection string — adjust host/port/user/pass/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/groundhog

# Bare model name (NOT the "groq/" prefix above) — the raw `groq` Python SDK
# client backend/app uses expects this format, cognee's litellm-style config
# does not. Kept as a separate variable from LLM_MODEL on purpose.
BACKEND_LLM_MODEL=llama-3.3-70b-versatile

API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Cognee memory server URL — backend/app calls this over HTTP instead of
# importing cognee directly (see backend/app/cognee_client.py).
COGNEE_API_URL=http://localhost:8010
COGNEE_CALL_TIMEOUT_SECONDS=60
# If the cognee server is down, fall back to Postgres-only behavior instead of
# failing the request. Set to false to make cognee outages loud (e.g. demo).
COGNEE_FALLBACK_ON_ERROR=true
