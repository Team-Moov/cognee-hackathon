GROQ_API_KEY="<YOUR_GROQ_API_KEY>"
LLM_MODEL="groq/llama-3.3-70b-versatile"

# File watcher directory (relative or absolute)
WATCHED_DIR="./watched_runs"

# Auto-improve trigger: call improve_memory() every N remember_run calls
IMPROVE_EVERY_N_RUNS=10

# Private/exploratory dataset prefix (shared dataset is always "main_dataset")
PRIVATE_DATASET_PREFIX="private"

# Server settings
HOST="0.0.0.0"
PORT=8000
