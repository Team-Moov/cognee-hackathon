# ═══════════════════════════════════════════════════════════════════════════
# Groundhog — environment configuration
# ═══════════════════════════════════════════════════════════════════════════
# Groundhog runs on ANY ONE of three chat providers. Pick one with
# GROUNDHOG_LLM_PROVIDER and set the matching key below. Embeddings run LOCALLY
# by default (fastembed, no key needed), so a single chat key is enough.

# ── Choose your chat/extraction provider: groq | gemini | aimlapi ────────────
GROUNDHOG_LLM_PROVIDER=groq

# ── Provider API keys (only the one matching the provider above is required) ──
GROQ_API_KEY="<YOUR_GROQ_API_KEY>"
GEMINI_API_KEY="<YOUR_GEMINI_API_KEY>"
AIMLAPI_API_KEY="<YOUR_AIMLAPI_API_KEY>"

# ── Optional model override ───────────────────────────────────────────────────
# Leave unset to use each provider's sensible default:
#   groq    -> groq/llama-3.3-70b-versatile
#   gemini  -> gemini/gemini-2.0-flash
#   aimlapi -> openai/gpt-4o-mini
# LLM_MODEL="groq/llama-3.3-70b-versatile"
# LLM_ENDPOINT=""   # only needed for a custom OpenAI-compatible base URL

# ── Embeddings (LOCAL by default — no API key, works offline after 1st download)
# Override only if you specifically want cloud embeddings.
#   fastembed (default): EMBEDDING_MODEL=BAAI/bge-small-en-v1.5  (384 dims)
#   gemini:              EMBEDDING_PROVIDER=gemini  EMBEDDING_MODEL=gemini/text-embedding-004
#   aimlapi:             EMBEDDING_PROVIDER=openai_compatible EMBEDDING_ENDPOINT=https://api.aimlapi.com/v1 EMBEDDING_API_KEY=<key>
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSIONS=384

# ── Behaviour toggles ─────────────────────────────────────────────────────────
# Also persist typed DataPoint nodes + edges (schema.py) — runs on local
# embeddings, no key needed. Set false to only ingest the text document.
GROUNDHOG_TYPED_NODES=true
# Enable cognee pipeline tracing (observability into how memory was built).
GROUNDHOG_TRACING=true
# Disable cognee 1.2 multi-tenant access control for simple local single-user dev.
ENABLE_BACKEND_ACCESS_CONTROL=false
# Pre-flight Guard semantic-match threshold (real vector similarity, 0..1).
PREFLIGHT_SIMILARITY_THRESHOLD=0.55

# File watcher directory (relative or absolute)
WATCHED_DIR="./watched_runs"

# Auto-improve trigger: call improve_memory() every N remember_run calls
IMPROVE_EVERY_N_RUNS=10

# Ontology grounding (Section 4.4) — override only if you move the .owl file.
# ONTOLOGY_FILE_PATH="./ontology/ml_ontology.owl"

# ── Cognee memory server (root main.py) ───────────────────────────────────────
# Port 8010, NOT 8000: backend/app/main.py is a Cognee-backed gateway that
# proxies requests over HTTP to this server.
HOST="0.0.0.0"
PORT=8010

# Bare model name for the raw `groq` SDK the backend app uses (no "groq/" prefix).
BACKEND_LLM_MODEL=llama-3.3-70b-versatile

API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# backend/app calls this over HTTP instead of importing cognee directly.
COGNEE_API_URL=http://localhost:8010
COGNEE_CALL_TIMEOUT_SECONDS=60
# If the cognee server is down, fail requests instead of falling back to a
# second database stack that no longer exists.
COGNEE_FALLBACK_ON_ERROR=false
