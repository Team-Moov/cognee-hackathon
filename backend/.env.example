# ── PostgreSQL ────────────────────────────────────────────────────────────────
# asyncpg connection string — adjust host/port/user/pass/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/groundhog

# ── Gemini ────────────────────────────────────────────────────────────────────
LLM_API_KEY=your-gemini-api-key          # used for both generation AND embeddings
LLM_MODEL=gemini-2.0-flash

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
