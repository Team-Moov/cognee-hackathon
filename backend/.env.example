# ── PostgreSQL ────────────────────────────────────────────────────────────────
# asyncpg connection string — adjust host/port/user/pass/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/groundhog

# ── Groq (text generation) ──────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
LLM_MODEL=llama-3.3-70b-versatile

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
